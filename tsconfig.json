{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"lib": ["ESNext"],
		"declaration": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "sample"]
}
